# ============================================
# Agentic MCP Chatbot — Environment Variables
# ============================================

# Choose your primary LLM Provider: "openrouter" or "gemini"
LLM_PROVIDER=openrouter
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LLM_TEMPERATURE=0.7

# OpenRouter (Primary)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Gemini (Fallback if OpenRouter fails)
GEMINI_API_KEY=AIzaSy...your-gemini-key-here

# --- Database (MongoDB for Persistence) ---
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=Agentic_MCP_Chatbot_DB

# --- Tool API Keys ---
TAVILY_API_KEY=tvly-your-tavily-key-here

# --- MCP Servers (JSON array) ---
# Example: [{"name": "search", "url": "http://localhost:8001/sse"}]
MCP_SERVERS_CONFIG=[]

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_key_here"
LANGCHAIN_PROJECT="Agentic-MCP-Chatbot"
